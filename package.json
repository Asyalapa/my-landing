{
  "name": "landing",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "scss": "sass scss/main.scss css/style.css --watch",
    "scss:build": "sass scss/main.scss css/style.css --no-source-map --style=compressed",
    "start": "node app.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run scss\" \"nodemon app.js\""
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "telegraf": "^4.15.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1",
    "sass": "^1.69.5",
    "vite": "^5.4.21"
  }
}
